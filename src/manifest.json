{
  "manifest_version": 3,
  "name": "Torrent Clipper",
  "version": "0.2.19.0",
  "description": "Add torrent and magnet links to your Bittorrent client's web interface. Modified to have seasonal anime",
  "default_locale": "en",
  "icons": {
    "32": "icon/default-32.png",
    "48": "icon/default-48.png",
    "64": "icon/default-64.png"
  },
  "options_ui": {
    "page": "view/options.html"
  },
  "action": {
    "default_area": "navbar",
    "default_icon": {
      "32": "icon/default-32.png",
      "48": "icon/default-48.png",
      "64": "icon/default-64.png"
    },
    "theme_icons": [{
      "light": "icon/default-light.svg",
      "dark": "icon/default.svg",
      "size": 32
    }, {
      "light": "icon/default-light.svg",
      "dark": "icon/default.svg",
      "size": 64
    }]
  },
  "permissions": [
    "contextMenus",
    "cookies",
    "downloads",
    "notifications",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "index.js",
    "type": "module"
  }
}
